---
interface Props {
  title?: string;
  isHome?: boolean;
}

const { title = "Guarantee — Rust SGX Attestation SDK for Gramine Enclaves", isHome = false } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content="Open-source Rust crate for Intel SGX attestation via Gramine. Add #[attest] to any axum handler — hardware-backed Ed25519 per-response signatures. MIT license. No SGX hardware needed for development." />
    <link rel="canonical" href="https://docs.guarantee.rs/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://docs.guarantee.rs/" />
    <meta property="og:site_name" content="Guarantee SDK" />
    <meta property="og:title" content="Guarantee — Rust SGX Attestation SDK · #[attest]" />
    <meta property="og:description" content="Open-source Rust crate. Add #[attest] to any axum handler. Every response gets a hardware-backed Ed25519 signature. MIT license." />
    <meta property="og:image" content="https://docs.guarantee.rs/og/sdk.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Guarantee SDK — #[attest] macro for Rust SGX attestation" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Guarantee — Rust SGX Attestation SDK" />
    <meta name="twitter:description" content="#[attest] any axum handler → Intel SGX Ed25519 signature on every response. Gramine. MIT license. No hardware for dev mode." />
    <meta name="twitter:image" content="https://docs.guarantee.rs/og/sdk.png" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareSourceCode",
      "name": "guarantee",
      "description": "Open-source Rust crate for Intel SGX attestation via Gramine. Adds hardware-backed Ed25519 per-response signatures to any axum web service.",
      "codeRepository": "https://github.com/susruth/guarantee",
      "programmingLanguage": "Rust",
      "runtimePlatform": "Intel SGX via Gramine",
      "license": "https://opensource.org/licenses/MIT",
      "version": "0.1.2",
      "url": "https://crates.io/crates/guarantee"
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="container">
      <header class={`site-header${isHome ? " site-header-home" : ""}`}>
        <div class="header-top">
          <a href="/" class="logo-text">Guarantee</a>
          <nav class="header-nav mono">
            <a href="/docs/getting-started" class={pathname.startsWith("/docs") ? "active" : ""}>Documentation</a>
            <a href="/verify" class={pathname === "/verify" || pathname === "/verify/" ? "active" : ""}>Verify</a>
            <a href="https://github.com/susruth/guarantee" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
            <a href="https://crates.io/crates/guarantee" target="_blank" rel="noopener noreferrer">Crates.io ↗</a>
          </nav>
        </div>
        <div class="header-bottom">
          <span>Open Source Rust TEE Attestation SDK</span>
          <span>v0.1.2</span>
        </div>
      </header>

      <slot />

      <footer class="site-footer mono">
        <div>Guarantee SDK // 2025</div>
        <div class="footer-links">
          <a href="/docs/getting-started">Documentation</a>
          <a href="/verify">Verify</a>
          <a href="https://github.com/susruth/guarantee" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
          <a href="https://crates.io/crates/guarantee" target="_blank" rel="noopener noreferrer">Crates.io ↗</a>
          <a href="https://guarantee.rs" target="_blank" rel="noopener noreferrer">guarantee.rs ↗</a>
          <a href="https://github.com/susruth/guarantee/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT License ↗</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
